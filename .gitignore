# -------------------------------------------------------------------
# Local environment files
# -------------------------------------------------------------------
.env
.env.*
*.env

# -------------------------------------------------------------------
# Kubernetes secret files
# 실제 비밀번호/토큰/키가 들어간 secret manifest는 올리지 않기
# 예시 파일만 Git에 올리기
# -------------------------------------------------------------------
*secret*.yaml
*secret*.yml
*secrets*.yaml
*secrets*.yml

!*secret*.example.yaml
!*secret*.example.yml
!*secrets*.example.yaml
!*secrets*.example.yml

# -------------------------------------------------------------------
# Kubeconfig / cluster access files
# -------------------------------------------------------------------
kubeconfig
kubeconfig.*
*.kubeconfig
.kube/

# -------------------------------------------------------------------
# Helm temporary files, if used later
# -------------------------------------------------------------------
charts/
*.tgz
Chart.lock

# -------------------------------------------------------------------
# Kustomize build output
# -------------------------------------------------------------------
kustomize-output.yaml
rendered.yaml
manifest.yaml
manifests.yaml

# -------------------------------------------------------------------
# ArgoCD local/session files, if any
# -------------------------------------------------------------------
.argocd/
argocd-context

# -------------------------------------------------------------------
# SSH keys / certificates
# -------------------------------------------------------------------
*.pem
*.key
*.crt
*.cer
*.p12

# -------------------------------------------------------------------
# OS files
# -------------------------------------------------------------------
.DS_Store
Thumbs.db

# -------------------------------------------------------------------
